# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Usually commit lockfiles for reproducible builds.
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Package manager caches
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# -----------------------------------------------------------------------------
# Build outputs
